    "@types/react": "~19.2.10",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.16",
    "jsdom": "^29.0.2",
    "react-test-renderer": "19.2.0",
    "sharp": "^0.34.5",
    "storybook": "^8.6.18",
    "typescript": "~5.9.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  },
  "expo": {
    "_install_exclude_reason": "expo install --fix tries to align react/react-dom to whatever the SDK pins. We pin them explicitly to 19.2.0 here + in overrides because (1) react-native 0.83.6 (SDK 55) ships a renderer that requires react ^19.2.0 and (2) downstream Storybook/vitest deps occasionally pull a newer 19.x peer that breaks the renderer at runtime. Until those deps drop their floating peer ranges, keep this exclude. @sentry/react-native está fixado em 7.13 (acima do ~7.2 que SDK 54 listava) porque a 7.2 tinha bug nativo que travava o JS thread por 51s no boot AAB de prod (MediaCodec + registerDefaultNetworkCallback rodando mesmo com replaysSessionSampleRate: 0). 7.13+ resolveu esse path no AAR. Mantido em 7.13 para SDK 55 também (versão minimum compat).",
    "install": {
      "exclude": [
        "react",
        "react-dom",
        "@sentry/react-native"
      ]
    },
    "_autolinking_exclude_reason": "@solana-mobile/mobile-wallet-adapter-protocol entra como dep transitiva via @clerk/clerk-js (clerk-js suporta Solana wallet auth). A gente não habilitou Solana no Clerk Dashboard, então clerk-js nunca chama a lib em runtime. Excluir do autolinking nativo evita compilar o package Kotlin/Java + reduz o tempo do gradle build.",
    "autolinking": {
      "exclude": [
        "@solana-mobile/mobile-wallet-adapter-protocol"
      ]
    }
  },
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "private": true
}
