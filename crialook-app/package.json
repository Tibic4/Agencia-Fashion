{
  "name": "crialook-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "_lock_warning": "EAS build espera lockfile no formato npm@10. NUNCA rode `npm install` puro neste app — sempre `npm run lock:fix` (ou `npm ci --legacy-peer-deps` em CI). npm 11+ regenera lockfile com sintaxe nova que quebra o EAS build. Nota M2 P7: Storybook 8.6.x×Vite 6.4.x peer-deps agora resolvem clean (vite@6.4.2 deduped na árvore inteira) — o `--legacy-peer-deps` continua necessário só pra contornar a peer mismatch transitiva do `@solana-mobile/mobile-wallet-adapter-protocol` (excluído via expo.autolinking) que arrasta `@solana/web3.js` com noble/hashes range incompatível.",
  "scripts": {
    "preinstall": "node scripts/preinstall-guard.js",
    "start": "expo start",
    "android": "expo start --android",
    "assetlinks:check": "node scripts/sync-assetlinks.js --check",
    "assetlinks:sync": "node scripts/sync-assetlinks.js",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "compress:bg": "node scripts/compress-bg.js",
    "lock:fix": "node -e \"require('fs').rmSync('package-lock.json',{force:true})\" && npx --yes npm@10 install --legacy-peer-deps",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rn": "jest",
    "test:rn:watch": "jest --watch",
    "check:legal-drift": "node scripts/check-legal-drift.js",
    "play:prep": "bash ../scripts/play-release-prep.sh",
    "play:secrets": "bash ../scripts/eas-secrets-prefill.sh",
    "play:apply-keys": "node ../scripts/apply-clerk-keys.js",
    "play:validate-deployed": "bash ../scripts/validate-assetlinks-deployed.sh",
    "play:validate-aab": "bash ../scripts/validate-aab-manifest.sh",
    "play:finalize": "bash ../scripts/play-store-finalize.sh",
    "play:preflight": "bash ../scripts/preflight-eas-build.sh",
    "storybook:dev": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static"
  },
