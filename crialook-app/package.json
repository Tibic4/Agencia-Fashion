{
  "name": "crialook-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "compress:bg": "node scripts/compress-bg.js",
    "lock:fix": "node -e \"require('fs').rmSync('package-lock.json',{force:true})\" && npx --yes npm@10 install --legacy-peer-deps",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rn": "jest",
    "test:rn:watch": "jest --watch",
    "storybook:dev": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.31",
    "@clerk/types": "^4.101.23",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.10",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-masked-view/masked-view": "^0.3.2",
    "@react-navigation/native": "^7.1.8",
    "@sentry/react-native": "~7.2.0",
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "2.2.12",
    "@tanstack/query-sync-storage-persister": "^5.62.0",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-query-persist-client": "^5.62.0",
    "expo": "~54.0.34",
    "expo-application": "~7.0.8",
    "expo-auth-session": "~7.0.11",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-keep-awake": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.8",
    "expo-mail-composer": "~15.0.8",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "~9.0.9",
    "expo-updates": "~29.0.17",
    "expo-web-browser": "~15.0.11",
    "i18n-js": "^4.5.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-iap": "^14.7.20",
    "react-native-mmkv": "^3.2.0",
    "react-native-nitro-modules": "^0.35.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react-vite": "^8.6.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-native": "^12.8.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "@vitejs/plugin-react": "^5.2.0",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "jsdom": "^29.0.2",
    "react-test-renderer": "19.1.0",
    "sharp": "^0.34.5",
    "storybook": "^8.6.18",
    "typescript": "~5.9.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  },
  "expo": {
    "_install_exclude_reason": "expo install --fix tries to align react/react-dom to whatever the SDK pins. We pin them explicitly to 19.1.0 here + in overrides because (1) react-native 0.81.5 ships a renderer that requires exactly 19.1.0 and (2) downstream Storybook/vitest deps occasionally pull a newer 19.x peer that breaks the renderer at runtime. Until those deps drop their floating peer ranges, keep this exclude.",
    "install": {
      "exclude": [
        "react",
        "react-dom"
      ]
    }
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "private": true
}
